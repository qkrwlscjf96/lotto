AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=apache/airflow:3.1.7
AIRFLOW_PROJ_DIR=.

POSTGRES_USER=airflow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=airflow

AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:change-me@postgres/airflow
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:change-me@postgres/airflow
AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0
AIRFLOW__CORE__FERNET_KEY=replace-with-a-generated-fernet-key

_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=change-me
_PIP_ADDITIONAL_REQUIREMENTS=
